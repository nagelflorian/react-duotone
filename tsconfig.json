{
  "compilerOptions": {
    "target": "ES2015",
    "module": "Node16",
    "lib": ["ES2015", "DOM"],
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node16",
    "declaration": true,
    "rootDir": "src",
    "outDir": "lib",
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/__tests__", "examples"]
}
